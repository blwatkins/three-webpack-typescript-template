{
  "name": "three-typescript-template",
  "version": "1.0.0",
  "description": "A template project for using Three.js with TypeScript and Webpack.",
  "private": true,
  "scripts": {
    "build:dev": "webpack --mode development",
    "build:dev:single-file": "webpack --mode development --config webpack.single-file.config.cjs",
    "build:prod": "webpack --mode production",
    "build:prod:single-file": "webpack --mode production --config webpack.single-file.config.cjs",
    "dev": "webpack-dev-server --mode development",
    "dev:single-file": "webpack-dev-server --mode development --config webpack.single-file.config.cjs",
    "dev:prod": "webpack-dev-server --mode production",
    "dev:prod:single-file": "webpack-dev-server --mode production --config webpack.single-file.config.cjs",
    "lint:js": "eslint -c eslint.config.js.mjs ./eslint.config.js.mjs ./eslint.config.ts.mjs ./webpack.config.cjs ./webpack.single-file.config.cjs",
    "lint:ts": "eslint -c eslint.config.ts.mjs ./src",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blwatkins/three-typescript-template.git"
  },
  "keywords": [
    "algorithmic art",
    "code art",
    "generative art",
    "three",
    "three.js",
    "threejs",
    "three-js",
    "typescript",
    "template"
  ],
  "author": {
    "name": "brittni watkins",
    "url": "https://blwatkins.github.io/"
  },
  "license": "MIT",
  "dependencies": {
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@types/three": "^0.182.0",
    "css-loader": "^7.1.3",
    "eslint": "^10.0.0",
    "eslint-plugin-es-x": "^9.4.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^3.0.1",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
